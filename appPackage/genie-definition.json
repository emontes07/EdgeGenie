{
  "openapi": "3.0.1",
  "info": {
    "version": "1.1.0",
    "title": "Edgewell Sales Genie API",
    "description": "API for Edgewell field sales recommendations, richer Adaptive Card display items, and retailer refinement guidance."
  },
  "servers": [
    {
      "url": "${{OPENAPI_SERVER_URL}}/api",
      "description": "Edgewell Sales Genie local or hosted API"
    }
  ],
  "paths": {
    "/products/recommendations": {
      "get": {
        "operationId": "getRecommendedProducts",
        "summary": "Get Edgewell sales recommendations",
        "description": "Returns seller-focused recommendation data plus card-ready display items for featured product cards, recommendation summary cards, comparison cards, product cards, refinement cards, and no-results fallback cards.",
        "parameters": [
          {
            "name": "age",
            "in": "query",
            "description": "Optional compatibility field kept for existing callers. It can be used as a loose audience hint.",
            "schema": { "type": "integer", "minimum": 0 },
            "required": false
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Optional compatibility field kept for existing callers. It can be used as a loose audience hint.",
            "schema": { "type": "string" },
            "required": false
          },
          {
            "name": "skinType",
            "in": "query",
            "description": "Legacy-compatible shopper segment hint that can still be used for sensitive, dry, oily, normal, or combination shopper needs.",
            "schema": {
              "type": "string",
              "enum": ["dry", "oily", "combination", "normal", "sensitive"]
            },
            "required": false
          },
          {
            "name": "concerns",
            "in": "query",
            "description": "One or more sales goals or positioning topics. Repeat the query parameter or provide a comma-separated list. Examples: competitive positioning, summer promotion, back-to-school, bundle, buyer pitch.",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required": false,
            "style": "form",
            "explode": true
          },
          {
            "name": "preference",
            "in": "query",
            "description": "Retailer, channel, or execution context such as Walmart, Target, summer, premium, value, bundle, or men's grooming.",
            "schema": { "type": "string" },
            "required": false
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Optional exact Edgewell brand filter such as Schick, Banana Boat, Wet Ones, Edge, or Skintimate.",
            "schema": { "type": "string" },
            "required": false
          },
          {
            "name": "minPrice",
            "in": "query",
            "description": "Optional minimum price filter.",
            "schema": { "type": "number", "minimum": 0 },
            "required": false
          },
          {
            "name": "maxPrice",
            "in": "query",
            "description": "Optional maximum price filter.",
            "schema": { "type": "number", "minimum": 0 },
            "required": false
          },
          {
            "name": "finish",
            "in": "query",
            "description": "Legacy-compatible merchandising cue retained for contract stability.",
            "schema": {
              "type": "string",
              "enum": ["matte", "dewy", "natural"]
            },
            "required": false
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of products to return. The API may also add a comparison card ahead of the products.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 6,
              "default": 3
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful sales recommendation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "getHealthStatus",
        "summary": "Get API health status",
        "description": "Simple health endpoint for local smoke tests and future Azure monitoring.",
        "responses": {
          "200": {
            "description": "Healthy response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RecommendationResponse": {
        "type": "object",
        "required": ["requestId", "status", "results"],
        "properties": {
          "requestId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["success", "no_results", "error"]
          },
          "results": {
            "$ref": "#/components/schemas/RecommendationResults"
          }
        }
      },
      "RecommendationResults": {
        "type": "object",
        "required": ["status", "generatedAt", "summary", "products", "displayItems", "refinements", "errors"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "no_results"]
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "query": {
            "$ref": "#/components/schemas/RecommendationQuery"
          },
          "summary": {
            "$ref": "#/components/schemas/RecommendationSummary"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductRecommendation"
            }
          },
          "displayItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisplayItem"
            }
          },
          "refinements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Refinement"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "RecommendationQuery": {
        "type": "object",
        "properties": {
          "age": { "type": "integer", "nullable": true },
          "gender": { "type": "string", "nullable": true },
          "skinType": { "type": "string", "nullable": true },
          "concerns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preference": { "type": "string", "nullable": true },
          "brand": { "type": "string", "nullable": true },
          "minPrice": { "type": "number", "nullable": true },
          "maxPrice": { "type": "number", "nullable": true },
          "finish": { "type": "string", "nullable": true },
          "limit": { "type": "integer" }
        }
      },
      "RecommendationSummary": {
        "type": "object",
        "required": ["headline", "recommendationReason", "appliedFilters", "resultCount", "presentationMode", "featuredProductId", "featuredReason", "refinementHint"],
        "properties": {
          "headline": { "type": "string" },
          "recommendationReason": { "type": "string" },
          "appliedFilters": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resultCount": { "type": "integer" },
          "presentationMode": {
            "type": "string",
            "enum": ["featured", "comparison", "list", "fallback"]
          },
          "featuredProductId": { "type": "string" },
          "featuredReason": { "type": "string" },
          "refinementHint": { "type": "string" }
        }
      },
      "ProductRecommendation": {
        "type": "object",
        "required": ["id", "productName", "brand", "category", "description", "imageUrl", "productUrl", "price", "rating", "reviewCount", "badges", "tags", "ranking", "recommendation", "facts"],
        "properties": {
          "id": { "type": "string" },
          "productName": { "type": "string" },
          "brand": { "type": "string" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "imageUrl": { "type": "string", "format": "uri" },
          "productUrl": { "type": "string", "format": "uri" },
          "keyBenefits": {
            "type": "array",
            "items": { "type": "string" }
          },
          "competitivePositioning": { "type": "string" },
          "retailerContext": {
            "type": "array",
            "items": { "type": "string" }
          },
          "bundleIdeas": {
            "type": "array",
            "items": { "type": "string" }
          },
          "talkingPoints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "objectionHandling": {
            "type": "array",
            "items": { "type": "string" }
          },
          "seasonality": {
            "type": "array",
            "items": { "type": "string" }
          },
          "suggestedPitch": { "type": "string" },
          "price": { "$ref": "#/components/schemas/ProductPrice" },
          "finish": { "type": "string" },
          "rating": { "type": "number" },
          "reviewCount": { "type": "integer" },
          "badges": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ranking": {
            "type": "object",
            "required": ["score", "reasonSignals"],
            "properties": {
              "score": { "type": "number" },
              "reasonSignals": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "recommendation": {
            "type": "object",
            "required": ["reasonShort", "reasonDetail"],
            "properties": {
              "reasonShort": { "type": "string" },
              "reasonDetail": { "type": "string" }
            }
          },
          "facts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FactItem"
            }
          }
        }
      },
      "ProductPrice": {
        "type": "object",
        "required": ["current", "original", "currency", "formattedCurrent", "formattedOriginal", "savingsText"],
        "properties": {
          "current": { "type": "number" },
          "original": { "type": "number" },
          "currency": { "type": "string" },
          "formattedCurrent": { "type": "string" },
          "formattedOriginal": { "type": "string" },
          "savingsText": { "type": "string" }
        }
      },
      "DisplayItem": {
        "type": "object",
        "required": ["cardType", "id", "title", "subtitle"],
        "properties": {
          "cardType": {
            "type": "string",
            "enum": ["featured", "list", "product", "comparison", "fallback", "refinement"]
          },
          "id": { "type": "string" },
          "rank": { "type": "integer", "nullable": true },
          "eyebrow": { "type": "string", "nullable": true },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "imageUrl": { "type": "string", "format": "uri", "nullable": true },
          "description": { "type": "string", "nullable": true },
          "recommendationReason": { "type": "string", "nullable": true },
          "reasonSignalsText": { "type": "string", "nullable": true },
          "sellingPointsText": { "type": "string", "nullable": true },
          "competitiveAngle": { "type": "string", "nullable": true },
          "suggestedPitch": { "type": "string", "nullable": true },
          "bundleIdea": { "type": "string", "nullable": true },
          "retailerContextText": { "type": "string", "nullable": true },
          "highlightLine": { "type": "string", "nullable": true },
          "badgeLine": { "type": "string", "nullable": true },
          "tagLine": { "type": "string", "nullable": true },
          "priceText": { "type": "string", "nullable": true },
          "originalPriceText": { "type": "string", "nullable": true },
          "savingsText": { "type": "string", "nullable": true },
          "ratingText": { "type": "string", "nullable": true },
          "facts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FactItem"
            }
          },
          "comparisonReason": { "type": "string", "nullable": true },
          "leftTitle": { "type": "string", "nullable": true },
          "leftSubtitle": { "type": "string", "nullable": true },
          "leftPriceText": { "type": "string", "nullable": true },
          "leftReasonText": { "type": "string", "nullable": true },
          "rightTitle": { "type": "string", "nullable": true },
          "rightSubtitle": { "type": "string", "nullable": true },
          "rightPriceText": { "type": "string", "nullable": true },
          "rightReasonText": { "type": "string", "nullable": true },
          "primaryActionTitle": { "type": "string", "nullable": true },
          "primaryActionUrl": { "type": "string", "format": "uri", "nullable": true },
          "secondaryActionTitle": { "type": "string", "nullable": true },
          "secondaryActionUrl": { "type": "string", "format": "uri", "nullable": true },
          "tertiaryActionTitle": { "type": "string", "nullable": true },
          "tertiaryActionUrl": { "type": "string", "format": "uri", "nullable": true }
        }
      },
      "FactItem": {
        "type": "object",
        "required": ["title", "value"],
        "properties": {
          "title": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "Refinement": {
        "type": "object",
        "required": ["id", "label", "url"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "ApiError": {
        "type": "object",
        "required": ["statusCode", "message"],
        "properties": {
          "statusCode": { "type": "integer" },
          "message": { "type": "string" },
          "details": { "type": "string", "nullable": true }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["requestId", "status", "error"],
        "properties": {
          "requestId": { "type": "string" },
          "status": { "type": "string", "enum": ["error"] },
          "error": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "service", "generatedAt", "catalogSize"],
        "properties": {
          "status": { "type": "string" },
          "service": { "type": "string" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "catalogSize": { "type": "integer" }
        }
      }
    }
  }
}
