{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "id": "${{TEAMS_APP_ID}}",
  "version": "1.1.0",
  "developer": {
    "name": "Edgewell Sales Genie Demo",
    "websiteUrl": "https://example.com/edgewell-sales-genie",
    "privacyUrl": "https://example.com/edgewell-sales-genie/privacy",
    "termsOfUseUrl": "https://example.com/edgewell-sales-genie/terms"
  },
  "icons": {
    "color": "Ulta-192.png",
    "outline": "Ulta-32.png"
  },
  "name": {
    "short": "Sales Genie",
    "full": "Edgewell Sales Genie"
  },
  "description": {
    "short": "Field sales recommendations, talking points, and buyer-ready pitches.",
    "full": "Edgewell Sales Genie is a declarative Microsoft 365 Copilot agent concept for Edgewell sellers. It helps teams position brands, build retailer-ready pitches, suggest bundles, and surface concise competitive talking points."
  },
  "accentColor": "#1F3B5B",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "geniebeauty",
        "file": "genie-declarative-agent.json"
      }
    ]
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ]
}
